---
import Layout from '../layouts/Layout.astro';

// Fetch latest blog posts from bot.mxjxn.com
let blogPosts: Array<{ title: string; slug: string; date: string; category: string }> = [];
try {
  const res = await fetch('https://bot.mxjxn.com/api/blog.json');
  if (res.ok) {
    const data = await res.json();
    blogPosts = (Array.isArray(data) ? data : data.posts || []).slice(0, 4);
  }
} catch {}

const now = new Date();
---

<Layout title="Max Jackson" description="Artist, builder, agent orchestrator. Making things with code, ink, and crypto. Currently in Rome.">

  <main class="page">

    <!-- Hero / Intro -->
    <section class="hero">
      <div class="avatar-ring">
        <img src="https://img.mxjxn.com/image/max-avatar.jpg" alt="Max Jackson" class="avatar" />
      </div>
      <h1 class="name">Max Jackson</h1>
      <p class="tagline">artist · builder · agent orchestrator</p>
      <p class="bio">
        Making things with code, ink, and crypto. Building autonomous agents,
        generative art systems, and tools that blur the line between human and machine creativity.
      </p>
      <div class="status">
        <span class="status-dot"></span>
        <span class="status-text">Currently in Rome</span>
      </div>
    </section>

    <!-- Featured -->
    <section class="featured">
      <h2 class="section-label">Current Focus</h2>
      <div class="featured-card">
        <span class="featured-tag">Residency</span>
        <h3 class="featured-title">Rome — Kismet Casa</h3>
        <p class="featured-desc">Printmaking, calligraphy, and street photography.
          Exploring ancient techniques through a contemporary lens.</p>
        <div class="featured-meta">
          <span class="featured-date">Apr — May 2026</span>
        </div>
      </div>
    </section>

    <!-- Art -->
    <section class="section">
      <h2 class="section-label">Art</h2>
      <div class="links">
        <a href="https://cryptoart.social" target="_blank" class="link-card">
          <span class="link-icon">🎨</span>
          <div>
            <span class="link-title">Cryptoart.social</span>
            <span class="link-sub">Auctionhouse &amp; marketplace</span>
          </div>
          <span class="link-arrow">↗</span>
        </a>
        <a href="https://warpcast.com/~/channel/cryptoart" target="_blank" class="link-card">
          <span class="link-icon">📻</span>
          <div>
            <span class="link-title">/cryptoart</span>
            <span class="link-sub">Host on Farcaster</span>
          </div>
          <span class="link-arrow">↗</span>
        </a>
        <div class="link-row">
          <a href="/glitch" class="link-card">
            <span class="link-icon">⚡</span>
            <div>
              <span class="link-title">Glitch Pipeline</span>
              <span class="link-sub">Image manipulation on Farcaster</span>
            </div>
            <span class="link-arrow">→</span>
          </a>
          <a href="https://mxjxn.github.io/wheelgen/" target="_blank" class="link-card">
            <span class="link-icon">🎡</span>
            <div>
              <span class="link-title">Wheelgen</span>
              <span class="link-sub">Generative color wheel tool</span>
            </div>
            <span class="link-arrow">↗</span>
          </a>
        </div>
      </div>
    </section>

    <!-- Projects -->
    <section class="section">
      <h2 class="section-label">Projects</h2>
      <div class="links">
        <a href="https://suchbot.mxjxn.com" target="_blank" class="link-card">
          <span class="link-icon">🤖</span>
          <div>
            <span class="link-title">Suchbot</span>
            <span class="link-sub">Autonomous AI agent on Farcaster</span>
          </div>
          <span class="link-arrow">↗</span>
        </a>
        <a href="https://snap.mxjxn.com" target="_blank" class="link-card">
          <span class="link-icon">⚡</span>
          <div>
            <span class="link-title">Such Snap</span>
            <span class="link-sub">Interactive Farcaster frames</span>
          </div>
          <span class="link-arrow">↗</span>
        </a>
      </div>
    </section>

    <!-- Links -->
    <section class="section">
      <h2 class="section-label">Links</h2>
      <div class="links">
        <a href="https://warpcast.com/mxjxn" target="_blank" class="link-card">
          <span class="link-icon">🔮</span>
          <div>
            <span class="link-title">Farcaster</span>
            <span class="link-sub">@mxjxn</span>
          </div>
          <span class="link-arrow">↗</span>
        </a>
        <div class="link-row">
          <a href="https://github.com/mxjxn" target="_blank" class="link-card">
            <span class="link-icon">🐙</span>
            <div>
              <span class="link-title">GitHub</span>
              <span class="link-sub">@mxjxn</span>
            </div>
            <span class="link-arrow">↗</span>
          </a>
          <a href="https://github.com/wowsuchbot" target="_blank" class="link-card">
            <span class="link-icon">🤖</span>
            <div>
              <span class="link-title">Suchbot</span>
              <span class="link-sub">@wowsuchbot</span>
            </div>
            <span class="link-arrow">↗</span>
          </a>
        </div>
        <div class="link-row">
          <a href="https://opensea.io/mxjxn" target="_blank" class="link-card">
            <span class="link-icon">🖼️</span>
            <div>
              <span class="link-title">OpenSea</span>
              <span class="link-sub">@mxjxn</span>
            </div>
            <span class="link-arrow">↗</span>
          </a>
          <a href="https://mxjxn.eth.limo" target="_blank" class="link-card">
            <span class="link-icon">🌐</span>
            <div>
              <span class="link-title">ENS</span>
              <span class="link-sub">mxjxn.eth</span>
            </div>
            <span class="link-arrow">↗</span>
          </a>
        </div>
      </div>
    </section>

    <!-- Latest Blog Posts -->
    {blogPosts.length > 0 && (
      <section class="section">
        <h2 class="section-label">Writing</h2>
        <div class="links">
          {blogPosts.map(post => (
            <a href={`https://bot.mxjxn.com/blog/${post.slug}/`} target="_blank" class="link-card">
              <span class="link-icon">✏️</span>
              <div>
                <span class="link-title">{post.title}</span>
                <span class="link-sub">{post.date}{post.category ? ` · ${post.category}` : ''}</span>
              </div>
              <span class="link-arrow">↗</span>
            </a>
          ))}
        </div>
      </section>
    )}

    <!-- Footer -->
    <footer class="footer">
      <p>© {now.getFullYear()} Max Jackson</p>
    </footer>

  </main>
</Layout>

<style>
  .page {
    max-width: 480px;
    margin: 0 auto;
    padding: 2rem 1.25rem 3rem;
  }

  /* Hero */
  .hero {
    text-align: center;
    padding: 1rem 0 2rem;
  }

  .avatar-ring {
    width: 80px;
    height: 80px;
    margin: 0 auto 1rem;
    border-radius: 50%;
    padding: 2px;
    background: linear-gradient(135deg, var(--accent), #6366f1, var(--accent-light));
  }

  .avatar {
    width: 100%;
    height: 100%;
    border-radius: 50%;
    object-fit: cover;
    display: block;
    border: 2px solid var(--bg);
  }

  .name {
    font-size: 1.75rem;
    letter-spacing: -0.03em;
    margin-bottom: 0.25rem;
  }

  .tagline {
    color: var(--text-muted);
    font-size: 0.85rem;
    letter-spacing: 0.02em;
    margin-bottom: 0.75rem;
  }

  .bio {
    color: var(--text-muted);
    font-size: 0.9rem;
    line-height: 1.6;
    max-width: 360px;
    margin: 0 auto 1rem;
  }

  .status {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.3rem 0.75rem;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 9999px;
    font-size: 0.75rem;
    color: var(--text-muted);
  }

  .status-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #34d399;
    animation: pulse 2s ease-in-out infinite;
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.4; }
  }

  .status-text {
    font-family: 'Space Mono', monospace;
  }

  /* Sections */
  .section {
    margin-bottom: 1.75rem;
  }

  .section-label {
    font-family: 'Space Mono', monospace;
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--text-muted);
    margin-bottom: 0.75rem;
  }

  /* Featured */
  .featured {
    margin-bottom: 1.75rem;
  }

  .featured-card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 1.25rem;
  }

  .featured-tag {
    display: inline-block;
    font-family: 'Space Mono', monospace;
    font-size: 0.65rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--accent-light);
    padding: 0.2rem 0.5rem;
    background: rgba(139, 92, 246, 0.12);
    border-radius: 4px;
    margin-bottom: 0.5rem;
  }

  .featured-title {
    font-size: 1.15rem;
    margin-bottom: 0.35rem;
  }

  .featured-desc {
    color: var(--text-muted);
    font-size: 0.85rem;
    line-height: 1.5;
    margin-bottom: 0.5rem;
  }

  .featured-date {
    font-family: 'Space Mono', monospace;
    font-size: 0.7rem;
    color: var(--text-muted);
  }

  /* Link cards */
  .links {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .link-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.5rem;
  }

  .link-card {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.85rem 1rem;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 10px;
    color: var(--text);
    text-decoration: none;
    transition: border-color 0.15s, transform 0.1s;
  }

  .link-card:hover {
    border-color: var(--accent);
    transform: translateY(-1px);
    color: var(--text);
  }

  .link-icon {
    font-size: 1.1rem;
    flex-shrink: 0;
    width: 28px;
    text-align: center;
  }

  .link-card > div {
    flex: 1;
    min-width: 0;
  }

  .link-title {
    display: block;
    font-weight: 600;
    font-size: 0.9rem;
    line-height: 1.3;
  }

  .link-sub {
    display: block;
    font-size: 0.75rem;
    color: var(--text-muted);
    font-family: 'Space Mono', monospace;
  }

  .link-arrow {
    color: var(--text-muted);
    font-size: 0.9rem;
    flex-shrink: 0;
    transition: color 0.15s;
  }

  .link-card:hover .link-arrow {
    color: var(--accent-light);
  }

  /* Footer */
  .footer {
    padding-top: 2rem;
    border-top: 1px solid var(--border);
    text-align: center;
  }

  .footer p {
    font-size: 0.75rem;
    color: var(--text-muted);
    font-family: 'Space Mono', monospace;
  }

  /* Mobile */
  @media (max-width: 480px) {
    .page {
      padding: 1.5rem 1rem 2.5rem;
    }
  }
</style>
