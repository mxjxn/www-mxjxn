---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const allPosts = (await getCollection('posts'))
  .filter((post) => !post.data.draft)
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());

const allTags = [...new Set(allPosts.flatMap((p) => p.data.tags ?? []))].sort();
const activeTag = Astro.url.searchParams.get('tag');
const posts = activeTag
  ? allPosts.filter((p) => (p.data.tags ?? []).includes(activeTag))
  : allPosts;

const formatDate = (d: string) =>
  new Date(d).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
---

<Layout title="Blog — Max Jackson" description="Writing about web development, AI systems, and creative tools.">
  <main class="blog-page">
    <a href="/" class="back-link">← Back</a>
    <h1 class="blog-title">Blog</h1>

    {allTags.length > 0 && (
      <div class="tag-filters">
        <a href="/blog" class:list={['tag-chip', { active: !activeTag }]}>All</a>
        {allTags.map((tag) => (
          <a
            href={`/blog?tag=${tag}`}
            class:list={['tag-chip', { active: tag === activeTag }]}
          >
            {tag}
          </a>
        ))}
      </div>
    )}

    {posts.length === 0 ? (
      <p class="empty-state">
        {activeTag ? `No posts tagged "${activeTag}" yet.` : 'No posts yet.'}
      </p>
    ) : (
      <div class="post-list">
        {posts.map((post) => (
          <a href={`/blog/${post.slug}/`} class="post-card">
            <div class="post-meta">
              <time datetime={post.data.date}>{formatDate(post.data.date)}</time>
              {(post.data.tags ?? []).map((tag: string) => (
                <span class="post-tag">{tag}</span>
              ))}
            </div>
            <h2 class="post-title">{post.data.title}</h2>
            <p class="post-excerpt">{post.data.excerpt}</p>
          </a>
        ))}
      </div>
    )}
  </main>
</Layout>

<style>
  .blog-page {
    max-width: 720px;
    margin: 0 auto;
    padding: 2rem 1.5rem 4rem;
  }

  .back-link {
    color: var(--text-muted);
    text-decoration: none;
    font-size: 0.85rem;
    display: inline-block;
    margin-bottom: 1.5rem;
  }
  .back-link:hover {
    color: var(--text-primary);
  }

  .blog-title {
    font-size: 1.75rem;
    margin-bottom: 1.5rem;
  }

  .tag-filters {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 2rem;
  }

  .tag-chip {
    padding: 0.25rem 0.75rem;
    border-radius: 999px;
    font-size: 0.78rem;
    text-decoration: none;
    color: var(--text-muted);
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.08);
    transition: all 0.15s;
  }
  .tag-chip:hover,
  .tag-chip.active {
    color: #a78bfa;
    border-color: #a78bfa;
    background: rgba(167, 139, 250, 0.1);
  }

  .empty-state {
    color: var(--text-muted);
    font-size: 0.9rem;
  }

  .post-list {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .post-card {
    display: block;
    text-decoration: none;
    color: inherit;
    padding: 1.25rem;
    border-radius: 12px;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.06);
    transition: border-color 0.15s, background 0.15s;
  }
  .post-card:hover {
    border-color: rgba(167, 139, 250, 0.3);
    background: rgba(255, 255, 255, 0.05);
  }

  .post-meta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 0.5rem;
    font-size: 0.78rem;
    color: var(--text-muted);
  }

  .post-tag {
    padding: 0.1rem 0.5rem;
    border-radius: 999px;
    font-size: 0.7rem;
    background: rgba(167, 139, 250, 0.1);
    color: #a78bfa;
  }

  .post-title {
    font-size: 1.1rem;
    margin-bottom: 0.4rem;
  }

  .post-excerpt {
    color: var(--text-muted);
    font-size: 0.85rem;
    line-height: 1.5;
  }
</style>
